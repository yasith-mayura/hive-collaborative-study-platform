# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/hive

# ─── Firebase Admin SDK (all services) ───────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-client-email@project.iam.gserviceaccount.com

# ─── JWT (auth-service) ───────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=1d

# ─── AWS S3 (resource-service) ────────────────────────────────────────────────
# Create bucket: aws s3api create-bucket --bucket hive-study-resources --region ap-southeast-1
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET_NAME=hive-study-resources

# ─── RAG Service (resource-service → rag-service) ────────────────────────────
RAG_SERVICE_URL=http://rag-service:8000

# ─── PGVector (rag-service) ───────────────────────────────────────────────────
PGVECTOR_HOST=pgvector
PGVECTOR_PORT=5432
PGVECTOR_DATABASE=hive_vectors
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=postgres

# ─── Service URLs (api-gateway) ───────────────────────────────────────────────
AUTH_SERVICE_URL=http://auth-service:3000
USER_SERVICE_URL=http://user-service:3001
RESOURCE_SERVICE_URL=http://resource-service:3002
CHAT_SERVICE_URL=http://chat-service:3003
NOTE_SERVICE_URL=http://note-service:3004
PROGRESS_SERVICE_URL=http://progress-service:3005
SESSION_SERVICE_URL=http://session-service:3006

# ─── RAG / AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSIONS=3072
