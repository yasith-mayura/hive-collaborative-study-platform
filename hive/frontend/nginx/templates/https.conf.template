    # ── Custom error pages (optional but recommended) ─────────────────────────────
    error_page 429 /429.json;
    error_page 502 503 504 /5xx.json;

    location = /429.json {
        internal;
        default_type application/json;
        return 429 '{"error":"Too many requests","retryAfter":1}';
    }

    location = /5xx.json {
